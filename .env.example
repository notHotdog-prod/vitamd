# .env.example — copy to .env.local and fill in your values

# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/vitamd?schema=public"

# JWT secret for admin sessions (generate with: openssl rand -base64 32)
JWT_SECRET="your-super-secret-jwt-key-here"

# Email (nodemailer) — use SMTP credentials or a service like SendGrid
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your@email.com"
SMTP_PASS="your-app-password"
CONTACT_EMAIL="hello@vitamd.com"

# Site URL
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="VitaMD"
